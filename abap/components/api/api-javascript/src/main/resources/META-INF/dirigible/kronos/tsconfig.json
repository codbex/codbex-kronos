{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "declaration": true,
    "types": [
      "../../../../../../target/unpacked-dependencies/META-INF/dirigible/modules/types",
      "./types"
    ],
    "paths": {
      "sdk/*": [
        "../../../../../../target/unpacked-dependencies/META-INF/dirigible/modules/src/*"
      ],
      "@aerokit/sdk/*": [
        "../../../../../../target/unpacked-dependencies/META-INF/dirigible/modules/src/*"
      ],
      "@abaplint/runtime": [
        "./node_modules/@abaplint/runtime/build/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}
